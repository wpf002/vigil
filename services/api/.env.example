# VIGIL Auth Service
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql://vigil:changeme@localhost:5433/vigil

# Shared signing secret. MUST match attack-state-engine and any other JWT
# verifying service. Rotate via planned outage; never commit a real secret.
AUTH_SECRET=replace-me-in-production-with-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Bootstrap secret for /auth/register/staff. Required value in the request
# body to register a vigil_analyst or vigil_admin account. Empty disables
# the endpoint entirely.
STAFF_REGISTRATION_KEY=
PLATFORM_TENANT_NAME=VIGIL Platform
