DATABASE_URL=postgresql://vigil:changeme@localhost:5433/vigil

# Temporal cluster.
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=vigil
TEMPORAL_TASK_QUEUE=vigil-playbooks

# Kafka — consumes escalations, publishes paused workflow notifications.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ATTACKS_ESCALATED=vigil.attacks.escalated
KAFKA_TOPIC_PLAYBOOKS_PAUSED=vigil.playbooks.paused
KAFKA_CONSUMER_GROUP=vigil-playbook-engine

# Outbound — used by activities to mark recommended_actions complete.
ATTACK_STATE_ENGINE_URL=http://localhost:8002
INTERNAL_API_KEY=dev-internal-key-change-me

# Narratives directory (response_playbooks live here).
NARRATIVES_PATH=attack-narratives

PORT=8007
LOG_LEVEL=INFO

# Auth — must match services/api so user JWTs validate.
AUTH_SECRET=replace-me-in-production-with-a-long-random-string
ENVIRONMENT=development

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
