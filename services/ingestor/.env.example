# VIGIL Ingestor

# Top-level dispatcher: es | core | hec | sentinel | elastic
SIEM_MODE=es

# ── Splunk (es / core / hec) ────────────────────────────────────────
SPLUNK_HOST=https://your-splunk-instance:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
SPLUNK_TOKEN=
SPLUNK_MODE=es
SPLUNK_VERIFY_SSL=false
SPLUNK_POLL_INTERVAL_SECONDS=30

# ── Microsoft Sentinel ──────────────────────────────────────────────
SENTINEL_TENANT_ID=
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_SUBSCRIPTION_ID=
SENTINEL_RESOURCE_GROUP=
SENTINEL_WORKSPACE_NAME=

# ── Elastic ─────────────────────────────────────────────────────────
ELASTIC_URL=
ELASTIC_API_KEY_ID=
ELASTIC_API_KEY_SECRET=
ELASTIC_VERIFY_SSL=true

# ── Kafka / Redis / ES ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SIGNALS=vigil.signals.raw
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

PORT=8001
LOG_LEVEL=INFO
TENANT_ID=default
