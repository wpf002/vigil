DATABASE_URL=postgresql://vigil:changeme@localhost:5433/vigil

# Kafka — escalations & paused playbooks land in escalation_queue.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ATTACKS_ESCALATED=vigil.attacks.escalated
KAFKA_TOPIC_PLAYBOOKS_PAUSED=vigil.playbooks.paused
KAFKA_CONSUMER_GROUP=vigil-analyst-portal

# Outbound proxy — read-only AttackState fetch.
ATTACK_STATE_ENGINE_URL=http://localhost:8002
INTERNAL_API_KEY=dev-internal-key-change-me

# Default SLA tiers (minutes).
SLA_CRITICAL_MINUTES=15
SLA_HIGH_MINUTES=30
SLA_MEDIUM_MINUTES=60
SLA_LOW_MINUTES=240

SLA_MONITOR_INTERVAL_SECONDS=60

PORT=8008
LOG_LEVEL=INFO

# Auth — must match services/api so user JWTs validate.
AUTH_SECRET=replace-me-in-production-with-a-long-random-string
ENVIRONMENT=development

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
