PORT=8006
LOG_LEVEL=INFO

# Claude API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Soft kill switch — set false in demo/Railway envs to stop all Claude calls.
# Defeated by env-var slip or stale deploy; ANTHROPIC_DAILY_CALL_BUDGET is the
# real backstop.
ANTHROPIC_ENABLED=true

# Hard daily call budget — Redis-backed, atomic, auto-resets at UTC midnight.
# Cannot be defeated by a missed env var; if Redis is unreachable, fails closed
# (no Claude calls). Set to 0 to disable Claude entirely.
ANTHROPIC_DAILY_CALL_BUDGET=50

# Per-process consecutive-error breaker. After this many errors in a row, the
# replica stops calling Claude until restart — stops a 30s-poll-forever loop
# the moment something structural breaks (bad auth, schema, quota).
ANTHROPIC_CONSECUTIVE_ERROR_LIMIT=5

# Where to PATCH narratives back. Same network as attack-state-engine.
ATTACK_STATE_ENGINE_URL=http://localhost:8002
INTERNAL_API_KEY=dev-internal-key-change-me

# Cache. REDIS_URL MUST include a /N database index path — without one,
# Redis defaults to DB 0 and the cache shares the namespace with other services.
REDIS_URL=redis://localhost:6380/1
NARRATIVE_CACHE_TTL_SECONDS=600
# Consumer skips a Claude call when a cached narrative for the same attack
# exists within this confidence delta. 0.15 absorbs typical demo progressions.
CONFIDENCE_DELTA_SKIP=0.15

# Kafka — listens on attacks.{created,updated} for state changes.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ATTACKS_CREATED=vigil.attacks.created
KAFKA_TOPIC_ATTACKS_UPDATED=vigil.attacks.updated
KAFKA_CONSUMER_GROUP=vigil-ai-engine
