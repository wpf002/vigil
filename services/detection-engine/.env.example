DATABASE_URL=postgresql://vigil:changeme@localhost:5433/vigil

PORT=8005
LOG_LEVEL=INFO

# JWT signing secret. MUST match services/api so user tokens validate here.
AUTH_SECRET=replace-me-in-production-with-a-long-random-string

# Toggles dev-only X-Tenant-Id bypass.
ENVIRONMENT=development

# Internal-only key for service-to-service signal recording (correlation-engine
# → detection-engine /internal/signals/record). Same value across services.
INTERNAL_API_KEY=dev-internal-key-change-me

# Compiled detections location (manifest.json + SIEM artifacts) and YAML source.
DETECTIONS_COMPILED_PATH=detections/compiled
DETECTIONS_YAML_PATH=detections/yaml

# Tenant under which the platform's built-in detections (D1–D4) are seeded.
PLATFORM_TENANT_ID=00000000-0000-0000-0000-000000000000

# How often the background aggregator runs (seconds). 1 hour by default.
PERFORMANCE_INTERVAL_SECONDS=3600

# Signal-translation service used by rollback to recompile prior YAML.
SIGNAL_TRANSLATION_URL=http://localhost:8004

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
