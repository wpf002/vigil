DATABASE_URL=postgresql://vigil:changeme@localhost:5433/vigil
REDIS_URL=redis://localhost:6380/0
ELASTICSEARCH_URL=http://localhost:9200

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SIGNALS=vigil.signals.raw
KAFKA_TOPIC_ATTACKS_CREATED=vigil.attacks.created
KAFKA_TOPIC_ATTACKS_UPDATED=vigil.attacks.updated
KAFKA_TOPIC_ATTACKS_ESCALATED=vigil.attacks.escalated

ESCALATION_CONFIDENCE_THRESHOLD=0.70
MOMENTUM_INCREASING_WINDOW_MINUTES=30
MOMENTUM_DECREASING_THRESHOLD_MINUTES=120

PORT=8002
LOG_LEVEL=INFO

# JWT signing secret. MUST match services/api so tokens are valid here too.
AUTH_SECRET=replace-me-in-production-with-a-long-random-string

# Toggles dev-only X-Tenant-Id bypass for the API.
ENVIRONMENT=development

# Shared internal-only key for service-to-service calls (e.g. ai-engine
# PATCHing narratives). Never exposed externally.
INTERNAL_API_KEY=dev-internal-key-change-me
