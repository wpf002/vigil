# VIGIL Reporting Service

ENVIRONMENT=development
PORT=8009
LOG_LEVEL=INFO

DATABASE_URL=postgresql://vigil:changeme@localhost:5433/vigil
REDIS_URL=redis://localhost:6379/2

# Shared HS256 secret with services/api.
AUTH_SECRET=replace-me-in-production-with-a-long-random-string

# Upstream service URLs.
API_URL=http://localhost:8000
ATTACK_STATE_ENGINE_URL=http://localhost:8002
DETECTION_ENGINE_URL=http://localhost:8005
ANALYST_PORTAL_URL=http://localhost:8008

INTERNAL_API_KEY=dev-internal-key-change-me

# Cache TTL for executive summary / trend in seconds.
CACHE_TTL_SECONDS=300

# Daily snapshot (UTC).
SNAPSHOT_HOUR_UTC=0
SNAPSHOT_MINUTE_UTC=5

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
