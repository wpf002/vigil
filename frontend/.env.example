VITE_API_URL=http://localhost:8002
VITE_AUTH_URL=http://localhost:8000

# Set to a string (e.g. "default") to enable the dev X-Tenant-Id header
# fallback when running the UI without the auth service. Leave empty in
# production so the only way to reach the API is with a real Bearer token.
VITE_DEV_TENANT_ID=
