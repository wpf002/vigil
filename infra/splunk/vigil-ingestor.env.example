# Point the VIGIL ingestor at the local free Splunk (infra/splunk).
# Copy the relevant lines into services/ingestor/.env, then restart the ingestor.
#
# VIGIL already ships Splunk connectors (services/ingestor/connectors/splunk_*).
# "core" mode polls fired saved-search alerts via the management REST API (8089).

SIEM_MODE=splunk
SPLUNK_MODE=core

# Management REST endpoint (NOT the web UI). Local Splunk from infra/splunk:
SPLUNK_HOST=https://localhost:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=Changeme123!

# Local Splunk uses a self-signed cert — don't verify it in dev.
SPLUNK_VERIFY_SSL=false

SPLUNK_POLL_INTERVAL_SECONDS=30
SPLUNK_MAX_EVENTS_PER_POLL=500
